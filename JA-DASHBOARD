<script>
/* ══════════════════════════════════════════
   CATÁLOGO DE NEGOCIOS — 6 entidades
══════════════════════════════════════════ */
const BIZ = {
  arzu:    {label:'Arzu Packing',  full:'Arzu Packing Service', grupo:'Inarzu', hex:'#0F766E', hexl:'#CCFBF1', hexd:'#134E4A'},
  ambaves: {label:'Ambaves',       full:'Ambaves',              grupo:'Inarzu', hex:'#059669', hexl:'#D1FAE5', hexd:'#065F46'},
  cosecha: {label:'Cosecha',       full:'Cosecha la Victoria',  grupo:'Inarzu', hex:'#15803D', hexl:'#DCFCE7', hexd:'#14532D'},
  publi:   {label:'Publibrand',    full:'Publibrand EC',        grupo:'',       hex:'#2563EB', hexl:'#EFF6FF', hexd:'#1E3A8A'},
  azshow:  {label:'AZShow',        full:'AZShow Business',      grupo:'',       hex:'#DB2777', hexl:'#FDF2F8', hexd:'#831843'},
  personal:{label:'Personal',      full:'Agenda Personal',      grupo:'',       hex:'#D97706', hexl:'#FFFBEB', hexd:'#78350F'},
};
const ALL_BIZ = Object.keys(BIZ);
const PORD = {alta:0, media:1, baja:2};
const TH   = {'30min':.5,'1h':1,'2h':2,'medio día':4,'1 día':8,'2–3 días':20,'1 semana':40};
const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
const DSEM  = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];

/* ══ STORAGE ══ */
const KT='ja3_tasks', KA='ja3_appts', KN='ja3_notas', KC='ja3_ctr';
let tasks=[], appts=[], notas=[], ctr=100;
function load(){
  try{tasks=JSON.parse(localStorage.getItem(KT)||'[]');}catch{tasks=[];}
  try{appts=JSON.parse(localStorage.getItem(KA)||'[]');}catch{appts=[];}
  try{notas=JSON.parse(localStorage.getItem(KN)||'[]');}catch{notas=[];}
  try{ctr=parseInt(localStorage.getItem(KC)||'100');}catch{ctr=100;}
}
function persist(){
  localStorage.setItem(KT,JSON.stringify(tasks));
  localStorage.setItem(KA,JSON.stringify(appts));
  localStorage.setItem(KN,JSON.stringify(notas));
  localStorage.setItem(KC,String(ctr));
}

/* ══ HELPERS ══ */
function ymd(d){return`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;}
function todayYMD(){return ymd(new Date());}
function fmtDate(s){if(!s)return'';const[y,m,d]=s.split('-');return`${d}/${m}/${y}`;}
function fmtShort(s){if(!s)return'';const[,m,d]=s.split('-');return`${d}/${m}`;}
function dlDays(s){if(!s)return null;return Math.ceil((new Date(s)-new Date(new Date().toDateString()))/86400000);}

/* ══ NAVIGATION ══ */
let page='inicio', tFilter='all', tSort='prioridad', calYear, calMonth, selDay, agWk=0;
const TITLES={inicio:'Inicio',calendario:'Calendario',tareas:'Tareas & Actividades',agenda:'Citas & Reuniones',notas:'Notas',metricas:'Métricas'};

function nav(el){
  document.querySelectorAll('.nav-item[data-page]').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  page=el.dataset.page;
  document.getElementById('page-title').textContent=TITLES[page]||'';
  closeSidebar(); render();
}
function goTareas(biz){
  document.querySelectorAll('.nav-item[data-page]').forEach(n=>n.classList.remove('active'));
  document.querySelector('[data-page="tareas"]').classList.add('active');
  page='tareas'; tFilter=biz;
  document.getElementById('page-title').textContent=TITLES.tareas;
  closeSidebar(); render();
}

/* ══ SIDEBAR MÓVIL ══ */
function toggleSidebar(){
  const s=document.getElementById('sidebar'),o=document.getElementById('overlay');
  const open=s.classList.toggle('open');
  o.classList.toggle('open',open);
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('open');
}

/* ══ MODALS ══ */
let editId=null;
function openModal(id,data){
  document.getElementById(id).classList.add('open');
  if(id==='modal-task'){
    editId=data?.id||null;
    document.getElementById('mt-h').textContent=editId?'Editar tarea':'Nueva tarea';
    document.getElementById('t-title').value=data?.title||'';
    document.getElementById('t-biz').value=data?.biz||'arzu';
    document.getElementById('t-pri').value=data?.pri||'alta';
    document.getElementById('t-dl').value=data?.dl||selDay||'';
    document.getElementById('t-time').value=data?.time||'';
    document.getElementById('t-notes').value=data?.notes||'';
  } else if(id==='modal-appt'){
    editId=data?.id||null;
    document.getElementById('ma-h').textContent=editId?'Editar cita':'Nueva cita / reunión';
    document.getElementById('a-title').value=data?.title||'';
    document.getElementById('a-biz').value=data?.biz||'arzu';
    document.getElementById('a-type').value=data?.type||'Reunión';
    document.getElementById('a-date').value=data?.date||selDay||todayYMD();
    document.getElementById('a-start').value=data?.start||'09:00';
    document.getElementById('a-end').value=data?.end||'10:00';
    document.getElementById('a-loc').value=data?.loc||'';
    document.getElementById('a-notes').value=data?.notes||'';
  } else if(id==='modal-nota'){
    editId=null;
    document.getElementById('n-biz').value='arzu';
    document.getElementById('n-text').value='';
  }
}
function closeModal(id){document.getElementById(id).classList.remove('open');editId=null;}
document.querySelectorAll('.modal-bg').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));

/* ══ CRUD ══ */
function saveTask(){
  const t=document.getElementById('t-title').value.trim();
  if(!t){alert('Escribe la descripción de la tarea.');return;}
  const o={id:editId||++ctr,title:t,biz:document.getElementById('t-biz').value,pri:document.getElementById('t-pri').value,dl:document.getElementById('t-dl').value,time:document.getElementById('t-time').value,notes:document.getElementById('t-notes').value,done:false,created:todayYMD()};
  if(editId){const i=tasks.findIndex(x=>x.id===editId);if(i>=0){o.done=tasks[i].done;tasks[i]=o;}}
  else tasks.push(o);
  persist(); closeModal('modal-task'); render();
}
function toggleTask(id){const t=tasks.find(x=>x.id===id);if(t){t.done=!t.done;persist();render();}}
function delTask(id){if(!confirm('¿Eliminar esta tarea?'))return;tasks=tasks.filter(x=>x.id!==id);persist();render();}

function saveAppt(){
  const t=document.getElementById('a-title').value.trim();
  if(!t){alert('Escribe el asunto.');return;}
  const o={id:editId||++ctr,title:t,biz:document.getElementById('a-biz').value,type:document.getElementById('a-type').value,date:document.getElementById('a-date').value,start:document.getElementById('a-start').value,end:document.getElementById('a-end').value,loc:document.getElementById('a-loc').value,notes:document.getElementById('a-notes').value};
  if(editId){const i=appts.findIndex(x=>x.id===editId);if(i>=0)appts[i]=o;}
  else appts.push(o);
  persist(); closeModal('modal-appt'); render();
}
function delAppt(id){if(!confirm('¿Eliminar esta cita?'))return;appts=appts.filter(x=>x.id!==id);persist();render();}

function saveNota(){
  const t=document.getElementById('n-text').value.trim();
  if(!t){alert('Escribe la nota.');return;}
  notas.push({id:++ctr,biz:document.getElementById('n-biz').value,text:t,created:todayYMD()});
  persist(); closeModal('modal-nota'); render();
}
function delNota(id){notas=notas.filter(x=>x.id!==id);persist();render();}

/* ══════════════════════════════════════════
   HTML HELPERS
══════════════════════════════════════════ */
function bizBadge(b){
  const x=BIZ[b]||BIZ.personal;
  return`<span class="biz-badge" style="background:${x.hexl};color:${x.hexd}"><span style="display:inline-block;width:5px;height:5px;border-radius:50%;background:${x.hex};margin-right:3px;flex-shrink:0"></span>${x.label}</span>`;
}
function dlBadge(s,done){
  if(!s||done)return'';
  const n=dlDays(s);
  const cls=n<0?'urg':n<=3?'warn':'';
  const txt=n<0?`Vencida ${-n}d`:n===0?'Hoy':n===1?'Mañana':`${fmtShort(s)} (${n}d)`;
  return`<span class="dl-tag ${cls}">${txt}</span>`;
}
function taskHTML(t){
  return`<div class="ti fade-up">
    <div class="ck ${t.done?'done':''}" onclick="toggleTask(${t.id})">
      ${t.done?`<svg width="9" height="7" viewBox="0 0 9 7"><path d="M1 3.5l2.5 2.5 4.5-5" stroke="white" stroke-width="1.6" stroke-linecap="round" fill="none"/></svg>`:''}
    </div>
    <div class="tb">
      <div class="tt ${t.done?'done':''}">${t.title}</div>
      ${t.notes?`<div style="font-size:11px;color:var(--muted);margin:3px 0;line-height:1.5">${t.notes}</div>`:''}
      <div class="tm">${bizBadge(t.biz)}<span class="tag ${t.done?'p-done':'p-'+t.pri}">${t.done?'Completada':t.pri}</span>${t.time?`<span class="tag" style="background:#F5F5F4;color:#57534E">${t.time}</span>`:''}${dlBadge(t.dl,t.done)}</div>
    </div>
    <div style="display:flex;gap:3px;flex-shrink:0">
      <button class="btn btn-xs btn-ghost" onclick='openModal("modal-task",${JSON.stringify(t)})'>✎</button>
      <button class="btn btn-xs btn-ghost" style="color:var(--danger)" onclick="delTask(${t.id})">✕</button>
    </div>
  </div>`;
}
function apptHTML(a){
  const b=BIZ[a.biz]||BIZ.personal;
  return`<div class="ai">
    <div class="ai-time">${a.start}<br><span style="color:var(--border)">${a.end}</span></div>
    <div class="ai-bar" style="background:${b.hex}"></div>
    <div class="ai-body" style="flex:1;min-width:0">
      <div class="ai-title">${a.title}</div>
      <div class="ai-sub">${bizBadge(a.biz)} · ${a.type}${a.loc?' · '+a.loc:''}</div>
      ${a.notes?`<div style="font-size:11px;color:var(--muted);margin-top:3px">${a.notes}</div>`:''}
    </div>
    <div style="display:flex;gap:3px;flex-shrink:0">
      <button class="btn btn-xs btn-ghost" onclick='openModal("modal-appt",${JSON.stringify(a)})'>✎</button>
      <button class="btn btn-xs btn-ghost" style="color:var(--danger)" onclick="delAppt(${a.id})">✕</button>
    </div>
  </div>`;
}

/* ══════════════════════════════════════════
   RENDER ENGINE
══════════════════════════════════════════ */
function render(){
  const c=document.getElementById('content');c.innerHTML='';
  ({inicio:rInicio,calendario:rCalendario,tareas:rTareas,agenda:rAgenda,notas:rNotas,metricas:rMetricas}[page]||rInicio)(c);
}

/* ── INICIO ── */
function rInicio(c){
  const pend=tasks.filter(t=>!t.done),done=tasks.filter(t=>t.done).length,tot=tasks.length;
  const venc=pend.filter(t=>t.dl&&dlDays(t.dl)<0).length;
  const urg=pend.filter(t=>t.dl&&dlDays(t.dl)>=0&&dlDays(t.dl)<=3).length;
  const pct=tot?Math.round(done/tot*100):0;
  const hoy=todayYMD();
  const hoyA=appts.filter(a=>a.date===hoy).sort((a,b)=>a.start.localeCompare(b.start));
  const alta=pend.filter(t=>t.pri==='alta').sort((a,b)=>new Date(a.dl||'9999')-new Date(b.dl||'9999'));

  // Resumen Inarzu
  const inarzuBizKeys=['arzu','ambaves','cosecha'];
  const inarzuPend=pend.filter(t=>inarzuBizKeys.includes(t.biz)).length;

  c.innerHTML=`
  <div class="g4" style="margin-bottom:12px">
    <div class="kpi" style="border-top-color:var(--inarzu)"><div class="kpi-val">${pct}%</div><div class="kpi-lbl">Productividad global</div></div>
    <div class="kpi" style="border-top-color:var(--danger)"><div class="kpi-val">${venc}</div><div class="kpi-lbl">Tareas vencidas</div></div>
    <div class="kpi" style="border-top-color:var(--warn)"><div class="kpi-val">${urg}</div><div class="kpi-lbl">Urgentes (≤3d)</div></div>
    <div class="kpi" style="border-top-color:var(--publi)"><div class="kpi-val">${done}/${tot}</div><div class="kpi-lbl">Completadas</div></div>
  </div>

  <!-- Resumen Inarzu -->
  <div class="card" style="margin-bottom:12px;border-left:3px solid var(--inarzu)">
    <div class="card-title">Inarzu Cía. Ltda. — resumen de las 3 líneas</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
      ${inarzuBizKeys.map(k=>{
        const b=BIZ[k];const bt=tasks.filter(t=>t.biz===k);const bd=bt.filter(t=>t.done).length;const p=bt.length?Math.round(bd/bt.length*100):0;
        return`<div style="background:${b.hexl};border-radius:8px;padding:10px 12px;border:1px solid ${b.hex}22">
          <div style="font-size:10px;font-weight:700;color:${b.hexd};margin-bottom:6px">${b.full}</div>
          <div style="font-size:18px;font-family:'DM Serif Display',serif;color:${b.hexd}">${p}%</div>
          <div style="font-size:10px;color:${b.hexd};opacity:.7;margin-top:2px">${bd}/${bt.length} tareas</div>
          <div style="height:4px;background:rgba(0,0,0,.1);border-radius:2px;margin-top:6px;overflow:hidden"><div style="height:100%;background:${b.hex};width:${p}%;border-radius:2px;transition:width .6s"></div></div>
        </div>`;
      }).join('')}
    </div>
  </div>

  <div class="g2">
    <div class="card">
      <div class="card-title">Alta prioridad — pendientes</div>
      ${alta.length?alta.slice(0,5).map(taskHTML).join(''):`<div class="empty">Sin urgentes 🎉</div>`}
    </div>
    <div>
      <div class="card" style="margin-bottom:12px">
        <div class="card-title">Hoy · ${new Date().toLocaleDateString('es-EC',{weekday:'long',day:'numeric',month:'long'})}</div>
        ${hoyA.length?hoyA.map(apptHTML).join(''):`<div class="empty" style="padding:12px 0">Sin citas hoy<br><button class="btn btn-xs" style="margin-top:8px" onclick="openModal('modal-appt')">+ Cita</button></div>`}
      </div>
      <div class="card">
        <div class="card-title">Progreso por negocio</div>
        ${ALL_BIZ.map(k=>{
          const bt=tasks.filter(t=>t.biz===k),bd=bt.filter(t=>t.done).length;
          const p=bt.length?Math.round(bd/bt.length*100):0;const b=BIZ[k];
          return`<div class="pr"><div class="pr-lbl">${b.label}</div><div class="pr-bg"><div class="pr-fill" style="width:${p}%;background:${b.hex}"></div></div><div class="pr-pct" style="color:${b.hexd}">${p}%</div></div>`;
        }).join('')}
      </div>
    </div>
  </div>`;
}

/* ── CALENDARIO ── */
function rCalendario(c){
  const today=todayYMD();
  const firstDay=new Date(calYear,calMonth,1);
  const lastDay=new Date(calYear,calMonth+1,0);
  let startDow=firstDay.getDay()-1;if(startDow<0)startDow=6;
  const mesStr=`${calYear}-${String(calMonth+1).padStart(2,'0')}`;
  const mesTasks=tasks.filter(t=>t.dl&&t.dl.startsWith(mesStr));
  const mesAppts=appts.filter(a=>a.date&&a.date.startsWith(mesStr));
  const evsByDay={};
  function addEv(date,ev){if(!evsByDay[date])evsByDay[date]=[];evsByDay[date].push(ev);}
  mesTasks.forEach(t=>{addEv(t.dl,{type:'task',hex:BIZ[t.biz].hex,hexl:BIZ[t.biz].hexl,hexd:BIZ[t.biz].hexd,label:t.title,done:t.done,pri:t.pri});});
  mesAppts.forEach(a=>{addEv(a.date,{type:'appt',hex:BIZ[a.biz].hex,hexl:BIZ[a.biz].hexl,hexd:BIZ[a.biz].hexd,label:a.title+' '+a.start});});
  const prevLast=new Date(calYear,calMonth,0).getDate();

  let cells='';
  let idx=0;
  for(let i=startDow-1;i>=0;i--){cells+=`<div class="cal-day other-month"><div class="cal-dn">${prevLast-i}</div></div>`;idx++;}
  for(let d=1;d<=lastDay.getDate();d++){
    const ds=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isT=ds===today,isSel=ds===selDay;
    const evs=evsByDay[ds]||[];
    const maxShow=2;
    const evH=evs.slice(0,maxShow).map(ev=>`<div class="cal-ev" style="background:${ev.hexl};color:${ev.hexd}${ev.done?';opacity:.5;text-decoration:line-through':''}">${ev.type==='appt'?'○ ':'● '}${ev.label}</div>`).join('');
    const dots=evs.length>maxShow?`<div class="cal-dot-row">${evs.slice(maxShow).map(ev=>`<div class="cal-dot" style="background:${ev.hex}" title="${ev.label}"></div>`).join('')}</div>`:'';
    cells+=`<div class="cal-day${isT?' today':''}${isSel?' selected':''}" onclick="selDate('${ds}')"><div class="cal-dn">${d}</div>${evH}${dots}</div>`;
    idx++;
  }
  const rem=idx%7===0?0:7-idx%7;
  for(let d=1;d<=rem;d++){cells+=`<div class="cal-day other-month"><div class="cal-dn">${d}</div></div>`;}

  const panelH=selDay?buildDayPanel(selDay):`<div style="color:var(--muted);font-size:13px;text-align:center;padding:40px 16px">Toca un día para ver sus actividades y citas</div>`;

  // Leyenda negocios
  const leyenda=ALL_BIZ.map(k=>`<div style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--muted)"><div style="width:8px;height:8px;border-radius:2px;background:${BIZ[k].hex}"></div>${BIZ[k].label}</div>`).join('');

  c.innerHTML=`
  <div style="display:grid;grid-template-columns:1fr 272px;gap:13px;align-items:start">
    <div>
      <div class="cal-wrap">
        <div class="cal-header">
          <div class="cal-month">${MESES[calMonth]} ${calYear}</div>
          <div style="display:flex;gap:4px">
            <button class="btn btn-xs btn-ghost" onclick="chgMes(-1)">‹</button>
            <button class="btn btn-xs btn-ghost" onclick="calYear=new Date().getFullYear();calMonth=new Date().getMonth();selDay='${today}';render()">Hoy</button>
            <button class="btn btn-xs btn-ghost" onclick="chgMes(1)">›</button>
          </div>
        </div>
        <div class="cal-grid">${DSEM.map(d=>`<div class="cal-dow">${d}</div>`).join('')}${cells}</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:8px;padding:0 2px">${leyenda}<span style="font-size:10px;color:var(--muted)">● Tarea &nbsp; ○ Cita</span></div>
    </div>
    <div class="day-panel">${panelH}</div>
  </div>`;
}

function buildDayPanel(ds){
  const[y,m,d]=ds.split('-');
  const nombreDia=new Date(+y,+m-1,+d).toLocaleDateString('es-EC',{weekday:'long',day:'numeric',month:'long'});
  const da=appts.filter(a=>a.date===ds).sort((a,b)=>a.start.localeCompare(b.start));
  const dt=tasks.filter(t=>t.dl===ds);
  let html=`<div class="day-panel-title">${nombreDia}</div>`;
  if(!da.length&&!dt.length){
    html+=`<div style="color:var(--muted);font-size:12px;text-align:center;padding:16px 0">Sin actividades<div style="display:flex;gap:6px;justify-content:center;margin-top:10px"><button class="btn btn-xs" onclick="selDay='${ds}';openModal('modal-task')">+ Tarea</button><button class="btn btn-xs" onclick="selDay='${ds}';openModal('modal-appt')">+ Cita</button></div></div>`;
    return html;
  }
  if(da.length){
    html+=`<div style="font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px">Citas (${da.length})</div>`;
    html+=da.map(a=>{const b=BIZ[a.biz]||BIZ.personal;return`<div style="border-left:3px solid ${b.hex};padding:6px 9px;background:${b.hexl};border-radius:0 6px 6px 0;margin-bottom:5px">
      <div style="font-size:11px;font-weight:700;color:${b.hexd}">${a.start}–${a.end} · ${a.title}</div>
      <div style="font-size:10px;color:var(--muted);margin-top:1px">${a.type}${a.loc?' · '+a.loc:''}</div>
      <div style="display:flex;gap:3px;margin-top:5px"><button class="btn btn-xs btn-ghost" onclick='openModal("modal-appt",${JSON.stringify(a)})'>✎ Editar</button><button class="btn btn-xs btn-ghost" style="color:var(--danger)" onclick="delAppt(${a.id})">✕</button></div>
    </div>`;}).join('');
  }
  if(dt.length){
    html+=`<div style="font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin:9px 0 7px">Tareas / deadline (${dt.length})</div>`;
    html+=dt.map(t=>{
      const b=BIZ[t.biz]||BIZ.personal;const n=dlDays(t.dl);
      return`<div style="border-left:3px solid ${b.hex};padding:6px 9px;background:${t.done?'#F9FAFB':b.hexl};border-radius:0 6px 6px 0;margin-bottom:5px${t.done?';opacity:.55':''}">
        <div style="font-size:11px;font-weight:700;color:${b.hexd};${t.done?'text-decoration:line-through':''}">${t.title}</div>
        <div style="display:flex;gap:4px;margin-top:4px;flex-wrap:wrap">
          <span class="tag p-${t.pri}" style="font-size:9px">${t.pri}</span>
          ${bizBadge(t.biz)}
          ${t.done?`<span class="tag p-done" style="font-size:9px">Completada</span>`:n!==null&&n<0?`<span class="tag p-vencida" style="font-size:9px">Vencida</span>`:n!==null&&n<=3?`<span class="tag p-urgente" style="font-size:9px">Urgente</span>`:''}
        </div>
        <div style="display:flex;gap:3px;margin-top:6px">
          <button class="btn btn-xs btn-ghost" onclick="toggleTask(${t.id})">${t.done?'↩ Reabrir':'✓ Listo'}</button>
          <button class="btn btn-xs btn-ghost" onclick='openModal("modal-task",${JSON.stringify(t)})'>✎</button>
          <button class="btn btn-xs btn-ghost" style="color:var(--danger)" onclick="delTask(${t.id})">✕</button>
        </div>
      </div>`;
    }).join('');
  }
  html+=`<div style="display:flex;gap:5px;margin-top:10px;padding-top:9px;border-top:1px solid var(--border)"><button class="btn btn-xs" style="flex:1" onclick="selDay='${ds}';openModal('modal-task')">+ Tarea</button><button class="btn btn-xs" style="flex:1" onclick="selDay='${ds}';openModal('modal-appt')">+ Cita</button></div>`;
  return html;
}
function selDate(d){selDay=d;render();}
function chgMes(n){calMonth+=n;if(calMonth>11){calMonth=0;calYear++;}if(calMonth<0){calMonth=11;calYear--;}render();}

/* ── TAREAS ── */
function rTareas(c){
  let list=[...tasks];
  if(tSort==='prioridad')list.sort((a,b)=>PORD[a.pri]-PORD[b.pri]||(a.done?1:-1));
  else if(tSort==='deadline')list.sort((a,b)=>new Date(a.dl||'9999')-new Date(b.dl||'9999'));
  else list.sort((a,b)=>a.biz.localeCompare(b.biz));
  if(tFilter!=='all')list=list.filter(t=>t.biz===tFilter);

  const filterBtns=[['all','Todos','#374151','#F3F4F6'],
    ['arzu','Arzu Packing',BIZ.arzu.hexd,BIZ.arzu.hexl],
    ['ambaves','Ambaves',BIZ.ambaves.hexd,BIZ.ambaves.hexl],
    ['cosecha','Cosecha',BIZ.cosecha.hexd,BIZ.cosecha.hexl],
    ['publi','Publibrand',BIZ.publi.hexd,BIZ.publi.hexl],
    ['azshow','AZShow',BIZ.azshow.hexd,BIZ.azshow.hexl],
    ['personal','Personal',BIZ.personal.hexd,BIZ.personal.hexl],
  ].map(([v,l,dk,bg])=>{const act=tFilter===v;return`<button onclick="tFilter='${v}';render()" style="padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:2px solid ${act?dk:'transparent'};background:${act?bg:'transparent'};color:${act?dk:'var(--muted)'};font-family:'DM Sans',sans-serif">${l}</button>`;}).join('');

  c.innerHTML=`
  <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;margin-bottom:12px">
    <div style="display:flex;gap:4px;flex-wrap:wrap">${filterBtns}</div>
    <div style="margin-left:auto;display:flex;gap:3px">
      ${[['prioridad','Prioridad'],['deadline','Deadline'],['negocio','Negocio']].map(([v,l])=>`<button onclick="tSort='${v}';render()" style="padding:4px 9px;border-radius:6px;font-size:11px;cursor:pointer;border:1px solid ${tSort===v?'#999':'var(--border)'};background:${tSort===v?'var(--text)':'transparent'};color:${tSort===v?'#fff':'var(--muted)'};font-family:'DM Sans',sans-serif">${l}</button>`).join('')}
    </div>
  </div>
  <div class="card">
    <div class="card-title"><span>${list.length} tarea${list.length!==1?'s':''}</span><span style="color:var(--success)">${list.filter(t=>t.done).length} completadas</span></div>
    ${list.length?list.map(taskHTML).join(''):`<div class="empty">Sin tareas en esta vista<br><button class="btn btn-xs" style="margin-top:10px" onclick="openModal('modal-task')">+ Agregar tarea</button></div>`}
  </div>`;
}

/* ── AGENDA ── */
function rAgenda(c){
  const today=new Date();today.setHours(0,0,0,0);
  const ws=new Date(today);ws.setDate(today.getDate()-today.getDay()+1+agWk*7);
  const we=new Date(ws);we.setDate(ws.getDate()+6);
  const fmt=d=>`${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}`;
  const inW=a=>a.date>=ymd(ws)&&a.date<=ymd(we);
  const wa=appts.filter(inW).sort((a,b)=>a.date.localeCompare(b.date)||a.start.localeCompare(b.start));
  const wt=tasks.filter(t=>t.dl&&t.dl>=ymd(ws)&&t.dl<=ymd(we)&&!t.done);
  const wDays=Array.from({length:7},(_,i)=>{const d=new Date(ws);d.setDate(ws.getDate()+i);return d;});
  c.innerHTML=`
  <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap">
    <button class="btn btn-xs btn-ghost" onclick="agWk--;render()">‹</button>
    <strong style="font-size:13px">${fmt(ws)} — ${fmt(we)}</strong>
    <button class="btn btn-xs btn-ghost" onclick="agWk++;render()">›</button>
    <button class="btn btn-xs btn-ghost" onclick="agWk=0;render()">Esta semana</button>
  </div>
  <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:12px" class="week-mini">
    ${wDays.map(d=>{
      const ds=ymd(d);const isT=ds===todayYMD();
      const da=appts.filter(a=>a.date===ds).length;const dt=tasks.filter(t=>t.dl===ds&&!t.done).length;
      return`<div style="text-align:center;padding:7px 3px;border-radius:8px;background:${isT?'var(--text)':'var(--surface)'};border:1px solid ${isT?'var(--text)':'var(--border)'}">
        <div style="font-size:9px;font-weight:700;color:${isT?'rgba(255,255,255,.6)':'var(--muted)'}">${DSEM[wDays.indexOf(d)]}</div>
        <div style="font-size:15px;font-family:'DM Serif Display',serif;color:${isT?'#fff':'var(--text)'}">${d.getDate()}</div>
        ${(da||dt)?`<div style="font-size:9px;color:${isT?'rgba(255,255,255,.6)':'var(--muted)'}">${da?da+'c':''} ${dt?dt+'t':''}</div>`:''}
      </div>`;
    }).join('')}
  </div>
  <div class="g2">
    <div class="card">
      <div class="card-title">Citas (${wa.length})</div>
      ${wa.length?wa.map(apptHTML).join(''):`<div class="empty">Sin citas<br><button class="btn btn-xs" style="margin-top:8px" onclick="openModal('modal-appt')">+ Agregar</button></div>`}
    </div>
    <div class="card">
      <div class="card-title">Deadlines esta semana (${wt.length})</div>
      ${wt.length?wt.map(taskHTML).join(''):`<div class="empty">Sin deadlines esta semana</div>`}
    </div>
  </div>`;
}

/* ── NOTAS ── */
function rNotas(c){
  const g={};notas.forEach(n=>{if(!g[n.biz])g[n.biz]=[];g[n.biz].push(n);});
  c.innerHTML=`<div style="display:flex;justify-content:flex-end;margin-bottom:11px"><button class="btn btn-primary btn-xs" onclick="openModal('modal-nota')">+ Nueva nota</button></div>
  ${Object.keys(g).length?ALL_BIZ.filter(k=>g[k]).map(k=>{
    const b=BIZ[k];
    return`<div style="margin-bottom:16px">
      <div style="font-size:10px;font-weight:700;color:${b.hexd};text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px;display:flex;align-items:center;gap:5px"><div style="width:7px;height:7px;border-radius:50%;background:${b.hex}"></div>${b.full}${b.grupo?' <span style="font-size:9px;color:var(--muted);font-weight:400;margin-left:3px">· '+b.grupo+'</span>':''}</div>
      ${g[k].map(n=>`<div class="note-item" style="border-left-color:${b.hex}"><div class="note-text">${n.text}</div><div style="font-size:10px;color:var(--muted);margin-top:5px">${fmtDate(n.created)}</div><button class="note-del" onclick="delNota(${n.id})">✕</button></div>`).join('')}
    </div>`;
  }).join(''):`<div class="empty" style="padding:50px 0">Sin notas aún<br><button class="btn btn-xs" style="margin-top:12px" onclick="openModal('modal-nota')">+ Primera nota</button></div>`}`;
}

/* ── MÉTRICAS ── */
function rMetricas(c){
  const tot=tasks.length,done=tasks.filter(t=>t.done).length;
  const pend=tasks.filter(t=>!t.done);
  const venc=pend.filter(t=>t.dl&&dlDays(t.dl)<0).length;
  const urg=pend.filter(t=>t.dl&&dlDays(t.dl)>=0&&dlDays(t.dl)<=3).length;
  const pct=tot?Math.round(done/tot*100):0;
  const totH=pend.reduce((s,t)=>s+(TH[t.time]||0),0);
  c.innerHTML=`
  <div class="g4" style="margin-bottom:12px">
    <div class="kpi" style="border-top-color:var(--inarzu)"><div class="kpi-val">${pct}%</div><div class="kpi-lbl">Productividad</div></div>
    <div class="kpi" style="border-top-color:var(--danger)"><div class="kpi-val">${venc}</div><div class="kpi-lbl">Vencidas</div></div>
    <div class="kpi" style="border-top-color:var(--warn)"><div class="kpi-val">${urg}</div><div class="kpi-lbl">Urgentes</div></div>
    <div class="kpi" style="border-top-color:var(--publi)"><div class="kpi-val">${Math.round(totH*10)/10}h</div><div class="kpi-lbl">Horas pend.</div></div>
  </div>

  <!-- Inarzu desglosado -->
  <div class="card" style="margin-bottom:12px;border-left:3px solid var(--inarzu)">
    <div class="card-title">Inarzu Cía. Ltda. — desglose por línea</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
      ${['arzu','ambaves','cosecha'].map(k=>{
        const b=BIZ[k];const bt=tasks.filter(t=>t.biz===k);const bd=bt.filter(t=>t.done).length;
        const pa=bt.filter(t=>!t.done&&t.pri==='alta').length;
        const p=bt.length?Math.round(bd/bt.length*100):0;
        return`<div style="background:${b.hexl};border-radius:8px;padding:11px 13px">
          <div style="font-size:10px;font-weight:700;color:${b.hexd};margin-bottom:6px">${b.full}</div>
          <div style="font-size:20px;font-family:'DM Serif Display',serif;color:${b.hexd}">${p}%</div>
          <div style="height:4px;background:rgba(0,0,0,.1);border-radius:2px;margin:5px 0;overflow:hidden"><div style="height:100%;background:${b.hex};width:${p}%;border-radius:2px"></div></div>
          <div style="font-size:10px;color:${b.hexd};opacity:.7">${bd}/${bt.length} · ${pa} alta prior.</div>
        </div>`;
      }).join('')}
    </div>
  </div>

  <div class="g2">
    <div class="card">
      <div class="card-title">Por negocio (todos)</div>
      ${ALL_BIZ.map(k=>{
        const bt=tasks.filter(t=>t.biz===k),bd=bt.filter(t=>t.done).length;
        const p=bt.length?Math.round(bd/bt.length*100):0;const b=BIZ[k];
        return`<div class="pr" style="margin-bottom:9px"><div class="pr-lbl">${b.label}</div><div class="pr-bg"><div class="pr-fill" style="width:${p}%;background:${b.hex}"></div></div><div class="pr-pct" style="color:${b.hexd}">${bd}/${bt.length}</div></div>`;
      }).join('')}
    </div>
    <div class="card">
      <div class="card-title">Por prioridad (pendientes)</div>
      ${['alta','media','baja'].map(p=>{
        const cnt=pend.filter(t=>t.pri===p).length;
        const p2=pend.length?Math.round(cnt/pend.length*100):0;
        const cols={alta:'var(--danger)',media:'var(--warn)',baja:'var(--success)'};
        return`<div class="pr" style="margin-bottom:9px"><div class="pr-lbl" style="text-transform:capitalize">${p}</div><div class="pr-bg"><div class="pr-fill" style="width:${p2}%;background:${cols[p]}"></div></div><div class="pr-pct">${cnt}</div></div>`;
      }).join('')}
      <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);font-size:12px;color:var(--muted)">Citas registradas: <strong style="color:var(--text)">${appts.length}</strong></div>
    </div>
  </div>
  <div class="card" style="margin-top:12px">
    <div class="card-title">Todas las tareas — tabla</div>
    <div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead><tr style="border-bottom:2px solid var(--border)">${['Tarea','Negocio','Prioridad','Deadline','Tiempo','Estado'].map(h=>`<th style="text-align:left;padding:6px 7px;font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;white-space:nowrap">${h}</th>`).join('')}</tr></thead>
      <tbody>${tasks.length?tasks.map(t=>{
        const n=dlDays(t.dl);
        const st=t.done?'<span class="tag p-done">Completada</span>':n!==null&&n<0?'<span class="tag p-vencida">Vencida</span>':n!==null&&n<=3?'<span class="tag p-urgente">Urgente</span>':'<span class="tag p-baja">Activa</span>';
        return`<tr style="border-bottom:1px solid var(--border)"><td style="padding:7px;max-width:170px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${t.title}</td><td style="padding:7px">${bizBadge(t.biz)}</td><td style="padding:7px"><span class="tag p-${t.pri}">${t.pri}</span></td><td style="padding:7px;font-size:11px;color:${n!==null&&n<=3&&!t.done?'var(--danger)':'var(--muted)'}">${fmtDate(t.dl)||'—'}</td><td style="padding:7px;color:var(--muted)">${t.time||'—'}</td><td style="padding:7px">${st}</td></tr>`;
      }).join(''):`<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--muted)">Sin tareas</td></tr>`}</tbody>
    </table></div>
  </div>`;
}

/* ══════════════════════════════════════════
   PWA — INSTALL PROMPT
══════════════════════════════════════════ */
let deferredPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();deferredPrompt=e;
  document.getElementById('install-banner').style.display='flex';
});
function installApp(){
  if(!deferredPrompt)return;
  deferredPrompt.prompt();
  deferredPrompt.userChoice.then(()=>{
    deferredPrompt=null;
    document.getElementById('install-banner').style.display='none';
  });
}

