}
html,body{height:100%;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);background:var(--bg);overscroll-behavior:none}

/* ══════════════════════════════════
   LAYOUT
══════════════════════════════════ */
.app{display:flex;height:100vh;overflow:hidden}
.sidebar{width:var(--sidebar-w);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;transition:transform .25s}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 16px;height:52px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:8px}
.content{flex:1;overflow-y:auto;padding:16px 18px;-webkit-overflow-scrolling:touch}

/* ══════════════════════════════════
   SIDEBAR
══════════════════════════════════ */
.brand{padding:16px 14px 12px;border-bottom:1px solid var(--border)}
.brand-name{font-family:'DM Serif Display',serif;font-size:16px;letter-spacing:-.2px}
.brand-sub{font-size:10px;color:var(--muted);margin-top:2px;font-weight:500;letter-spacing:.04em;text-transform:uppercase}
.nav-sec{padding:13px 12px 4px;font-size:9px;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 10px;cursor:pointer;border-radius:8px;margin:1px 5px;font-size:12.5px;color:var(--muted);transition:all .13s;user-select:none;white-space:nowrap;overflow:hidden}
.nav-item:hover{background:var(--bg);color:var(--text)}
.nav-item.active{background:var(--text);color:#fff}
.nav-item svg{width:13px;height:13px;flex-shrink:0;opacity:.8}
.nav-item.active svg{opacity:1}
.biz-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
/* Subgrupo Inarzu */
.nav-subgroup{margin-left:10px;border-left:2px solid var(--border);padding-left:2px}
.nav-sub{font-size:11.5px;padding:5px 8px;margin:1px 4px;border-radius:6px}

/* ══════════════════════════════════
   HAMBURGER (móvil)
══════════════════════════════════ */
.hamburger{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:6px;border-radius:6px;background:transparent;border:none}
.hamburger span{display:block;width:18px;height:1.5px;background:var(--text);border-radius:2px;transition:all .2s}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:90}
.sidebar-overlay.open{display:block}
@media(max-width:720px){
  .hamburger{display:flex}
  .sidebar{position:fixed;top:0;left:0;height:100%;z-index:100;transform:translateX(-100%);width:260px}
  .sidebar.open{transform:translateX(0)}
  .content{padding:12px 14px}
  .g4{grid-template-columns:1fr 1fr!important}
  .g2,.g3{grid-template-columns:1fr!important}
  .cal-day{min-height:58px}
  .cal-ev{display:none}
  .week-mini{display:none}
}

/* ══════════════════════════════════
   BOTONES
══════════════════════════════════ */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 12px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border);background:var(--surface);color:var(--text);transition:all .13s;font-family:'DM Sans',sans-serif;white-space:nowrap;-webkit-appearance:none}
.btn:hover{background:var(--bg)}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--text);color:#fff;border-color:var(--text)}
.btn-primary:hover{opacity:.86}
.btn-xs{padding:4px 9px;font-size:11px;border-radius:6px}
.btn-ghost{border-color:transparent;background:transparent}
.btn-ghost:hover{background:var(--bg)}

/* ══════════════════════════════════
   CARDS
══════════════════════════════════ */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;margin-bottom:13px}
.card-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}

/* KPI */
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;border-top:3px solid transparent}
.kpi-val{font-family:'DM Serif Display',serif;font-size:26px;line-height:1.1}
.kpi-lbl{font-size:11px;color:var(--muted);margin-top:4px}

/* TAGS */
.tag{display:inline-flex;align-items:center;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;white-space:nowrap}
.p-alta{background:#FEE2E2;color:#991B1B}
.p-media{background:#FEF3C7;color:#92400E}
.p-baja{background:#D1FAE5;color:#065F46}
.p-done{background:#F0FDF4;color:#166534}
.p-vencida{background:#FEE2E2;color:#991B1B}
.p-urgente{background:#FEF3C7;color:#92400E}

/* ══════════════════════════════════
   TASK ITEM
══════════════════════════════════ */
.ti{display:flex;align-items:flex-start;gap:10px;padding:11px 0;border-bottom:1px solid var(--border)}
.ti:last-child{border-bottom:none;padding-bottom:0}
.ck{width:18px;height:18px;border-radius:5px;border:1.5px solid #ccc;flex-shrink:0;margin-top:1px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .13s}
.ck:hover{border-color:var(--success)}
.ck.done{background:var(--success);border-color:var(--success)}
.tb{flex:1;min-width:0}
.tt{font-size:13px;line-height:1.4}
.tt.done{text-decoration:line-through;color:var(--muted)}
.tm{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;align-items:center}
.biz-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600}
.dl-tag{font-size:11px;color:var(--muted)}
.dl-tag.urg{color:var(--danger);font-weight:600}
.dl-tag.warn{color:#B45309;font-weight:500}

/* APPT */
.ai{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--border)}
.ai:last-child{border-bottom:none}
.ai-bar{width:3px;border-radius:3px;flex-shrink:0;min-height:34px}
.ai-time{font-size:11px;color:var(--muted);min-width:40px;padding-top:1px}
.ai-body{flex:1;min-width:0}
.ai-title{font-size:13px;font-weight:500}
.ai-sub{font-size:11px;color:var(--muted);margin-top:2px}

/* PROGRESS */
.pr{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.pr-lbl{font-size:11px;color:var(--muted);width:72px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pr-bg{flex:1;height:7px;background:var(--bg);border-radius:4px;overflow:hidden;border:1px solid var(--border)}
.pr-fill{height:100%;border-radius:4px;transition:width .6s}
.pr-pct{font-size:11px;font-weight:600;min-width:28px;text-align:right}

/* ══════════════════════════════════
   CALENDARIO
══════════════════════════════════ */
.cal-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.cal-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border)}
.cal-month{font-family:'DM Serif Display',serif;font-size:17px}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr)}
.cal-dow{text-align:center;padding:7px 2px;font-size:9px;font-weight:700;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;border-bottom:1px solid var(--border)}
.cal-day{min-height:82px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:5px 4px 3px;cursor:pointer;transition:background .12s;position:relative}
.cal-day:nth-child(7n){border-right:none}
.cal-day:hover{background:#FAFAF9}
.cal-day.other-month .cal-dn{color:var(--border)}
.cal-day.today .cal-dn{background:var(--text);color:#fff;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-weight:600}
.cal-day.selected{background:#FFFEF0;outline:2px solid var(--warn);outline-offset:-1px}
.cal-dn{font-size:11px;font-weight:500;color:var(--text);margin-bottom:3px;width:20px;height:20px;display:flex;align-items:center;justify-content:center}
.cal-ev{border-radius:3px;padding:2px 4px;font-size:8.5px;font-weight:600;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.4}
.cal-more{font-size:9px;color:var(--muted);padding-left:2px}
.cal-dot-row{display:flex;gap:2px;flex-wrap:wrap;padding-top:2px}
.cal-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}

/* PANEL DÍA */
.day-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.day-panel-title{font-family:'DM Serif Display',serif;font-size:15px;margin-bottom:11px;padding-bottom:9px;border-bottom:1px solid var(--border)}

/* ══════════════════════════════════
   MODAL
══════════════════════════════════ */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:flex-start;justify-content:center;padding:48px 10px 20px;overflow-y:auto}
.modal-bg.open{display:flex}
.modal{background:var(--surface);border-radius:14px;padding:20px;width:420px;max-width:100%;border:1px solid var(--border)}
.modal-title{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:14px}
.fg{margin-bottom:10px}
.fg label{display:block;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
.fg input,.fg select,.fg textarea{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:7px;font-size:13px;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text)}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:#999;background:var(--surface)}
.fg textarea{height:64px;resize:vertical}
.frow{display:flex;gap:8px}
.frow .fg{flex:1}
.modal-footer{display:flex;gap:7px;justify-content:flex-end;margin-top:6px;padding-top:12px;border-top:1px solid var(--border)}

/* NOTAS */
.note-item{background:var(--bg);border-radius:8px;padding:10px 12px;margin-bottom:7px;border-left:3px solid transparent;position:relative}
.note-text{font-size:13px;line-height:1.6}
.note-del{position:absolute;top:8px;right:8px;background:transparent;border:none;cursor:pointer;color:var(--muted);opacity:0;transition:opacity .13s;font-size:13px}
.note-item:hover .note-del{opacity:1}

/* INSTALL BANNER */
.install-banner{background:var(--text);color:#fff;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;gap:10px;font-size:12px;flex-shrink:0}
.install-banner button{background:#fff;color:var(--text);border:none;border-radius:6px;padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}

.empty{text-align:center;padding:24px 0;color:var(--muted);font-size:13px}
@keyframes fadeUp{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.fade-up{animation:fadeUp .17s ease}
</style>
